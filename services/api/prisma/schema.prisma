generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Address {
  id           Int      @id @default(autoincrement())
  user_id      Int
  full_name    String?  @db.VarChar(255)
  phone        String?  @db.VarChar(30)
  address_line String?  @db.VarChar(255)
  ward         String?  @db.VarChar(255)
  district     String?  @db.VarChar(255)
  province     String?  @db.VarChar(255)
  created_at   DateTime @default(now()) @db.Timestamp(0)
  User        User    @relation(fields: [user_id], references: [id], onUpdate: Restrict, map: "fk_addresses_user")

  @@index([user_id], map: "fk_addresses_user")
  @@map("addresses")
}

model AiChat {
  id          Int           @id @default(autoincrement())
  user_id     Int?
  created_at  DateTime      @default(now()) @db.Timestamp(0)
  User       User?        @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "ai_chats_ibfk_1")
  AiMessage AiMessage[]

  @@index([user_id], map: "user_id")
  @@map("ai_chats")
}

model AiMessage {
  id         Int       @id @default(autoincrement())
  chat_id    Int?
  sender     String?   @db.VarChar(20)
  message    String?   @db.Text
  created_at DateTime  @default(now()) @db.Timestamp(0)
  AiChat   AiChat? @relation(fields: [chat_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "ai_messages_ibfk_1")

  @@index([chat_id], map: "chat_id")
  @@map("ai_messages")
}

model AttributeValue {
  id                                                                          Int                   @id @default(autoincrement())
  attribute_id                                                                Int?
  value                                                                       String?               @db.VarChar(100)
  Attribute                                                                  Attribute?           @relation(fields: [attribute_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "attribute_values_ibfk_1")
  compatibility_rules_compatibility_rules_attribute_value_1Toattribute_values CompatibilityRule[] @relation("compatibility_rules_attribute_value_1Toattribute_values")
  compatibility_rules_compatibility_rules_attribute_value_2Toattribute_values CompatibilityRule[] @relation("compatibility_rules_attribute_value_2Toattribute_values")
  SkuAttribute                                                              SkuAttribute[]

  @@index([attribute_id], map: "attribute_id")
  @@map("attribute_values")
}

model Attribute {
  id               Int                @id @default(autoincrement())
  name             String?            @db.VarChar(100)
  AttributeValue AttributeValue[]
  @@map("attributes")
}

model Brand {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(255)
  slug       String?    @db.VarChar(255)
  logo_url   String?    @db.VarChar(255)
  status     String?    @default("ACTIVE") @db.VarChar(50)
  is_active  Boolean?   @default(true)
  created_at DateTime?  @default(now()) @db.Timestamp(0)
  updated_at DateTime?  @default(now()) @db.Timestamp(0)
  Product   Product[]
  @@map("brands")
}

model CartItem {
  id                 Int          @id @default(autoincrement())
  cart_id            Int
  product_variant_id Int
  quantity           Int          @default(1)
  created_at         DateTime     @default(now()) @db.Timestamp(0)
  updated_at         DateTime     @default(now()) @db.Timestamp(0)
  Cart              Cart        @relation(fields: [cart_id], references: [id], onUpdate: Restrict, map: "fk_cart_items_cart")
  ProductSku       ProductSku @relation(fields: [product_variant_id], references: [id], onUpdate: Restrict, map: "fk_cart_items_sku")

  @@index([cart_id], map: "fk_cart_items_cart")
  @@index([product_variant_id], map: "fk_cart_items_sku")
  @@map("cart_items")
}

model Cart {
  id         Int          @id @default(autoincrement())
  user_id    Int
  created_at DateTime     @default(now()) @db.Timestamp(0)
  updated_at DateTime     @default(now()) @db.Timestamp(0)
  CartItem CartItem[]
  User      User        @relation(fields: [user_id], references: [id], onUpdate: Restrict, map: "fk_carts_user")

  @@index([user_id], map: "fk_carts_user")
  @@map("carts")
}

model Category {
  id       Int        @id @default(autoincrement())
  name     String?    @db.VarChar(100)
  Product Product[]
  @@map("categories")
}

model CompatibilityRule {
  id                                                                       Int               @id @default(autoincrement())
  attribute_value_1                                                        Int?
  attribute_value_2                                                        Int?
  is_compatible                                                            Boolean?
  source_category_id                                                       Int?
  target_category_id                                                       Int?
  source_attribute_key                                                     String?           @db.VarChar(255)
  target_attribute_key                                                     String?           @db.VarChar(255)
  operator                                                                 String?           @default("EQ") @db.VarChar(20)
  description                                                              String?           @db.Text
  status                                                                   String?           @default("ACTIVE") @db.VarChar(50)
  is_active                                                                Boolean?          @default(true)
  created_at                                                               DateTime?         @default(now()) @db.Timestamp(0)
  updated_at                                                               DateTime?         @default(now()) @db.Timestamp(0)
  attribute_values_compatibility_rules_attribute_value_1Toattribute_values AttributeValue? @relation("compatibility_rules_attribute_value_1Toattribute_values", fields: [attribute_value_1], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "compatibility_rules_ibfk_1")
  attribute_values_compatibility_rules_attribute_value_2Toattribute_values AttributeValue? @relation("compatibility_rules_attribute_value_2Toattribute_values", fields: [attribute_value_2], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "compatibility_rules_ibfk_2")

  @@index([attribute_value_1], map: "attribute_value_1")
  @@index([attribute_value_2], map: "attribute_value_2")
  @@map("compatibility_rules")
}

model OrderItem {
  id                 Int          @id @default(autoincrement())
  order_id           Int
  product_variant_id Int
  quantity           Int          @default(1)
  unit_price         Decimal      @default(0.00) @db.Decimal(12, 2)
  line_total         Decimal      @default(0.00) @db.Decimal(12, 2)
  product_id         Int?
  sku_snapshot       String?      @db.VarChar(255)
  name_snapshot      String?      @db.VarChar(255)
  created_at         DateTime?    @default(now()) @db.Timestamp(0)
  updated_at         DateTime?    @default(now()) @db.Timestamp(0)
  Order             Order       @relation(fields: [order_id], references: [id], onUpdate: Restrict, map: "fk_order_items_order")
  ProductSku       ProductSku @relation(fields: [product_variant_id], references: [id], onUpdate: Restrict, map: "fk_order_items_sku")
  WarrantyItem         WarrantyItem?

  @@index([order_id], map: "fk_order_items_order")
  @@index([product_variant_id], map: "fk_order_items_sku")
  @@map("order_items")
}

model Order {
  id               Int           @id @default(autoincrement())
  user_id          Int?
  total_price      Decimal?      @db.Decimal(10, 2)
  status           String?       @db.VarChar(50)
  created_at       DateTime      @default(now()) @db.Timestamp(0)
  address_id       Int?
  total_amount     Decimal?      @db.Decimal(12, 2)
  shipping_fee     Decimal?      @default(0.00) @db.Decimal(12, 2)
  final_amount     Decimal?      @db.Decimal(12, 2)
  shipping_address String?       @db.Text
  payment_method   String?       @default("COD") @db.VarChar(50)
  payment_status   String?       @default("UNPAID") @db.VarChar(50)
  note             String?       @db.Text
  updated_at       DateTime?     @default(now()) @db.Timestamp(0)
  OrderItem      OrderItem[]
  Shipment        Shipment[]
  WarrantyItem       WarrantyItem[]
  @@map("orders")
}

model PcBuildItem {
  id             Int           @id @default(autoincrement())
  build_id       Int?
  sku_id         Int?
  component_type String?       @db.VarChar(50)
  PcBuild      PcBuild?    @relation(fields: [build_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "pc_build_items_ibfk_1")
  ProductSku   ProductSku? @relation(fields: [sku_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "pc_build_items_ibfk_2")

  @@index([build_id], map: "build_id")
  @@index([sku_id], map: "sku_id")
  @@map("pc_build_items")
}

model PcBuild {
  id             Int              @id @default(autoincrement())
  user_id        Int?
  name           String?          @db.VarChar(100)
  created_at     DateTime         @default(now()) @db.Timestamp(0)
  updated_at     DateTime?        @default(now()) @db.Timestamp(0)
  status         String?          @default("DRAFT") @db.VarChar(50)
  is_saved       Boolean?         @default(false)
  total_price    Decimal?         @default(0.00) @db.Decimal(12, 2)
  PcBuildItem PcBuildItem[]
  User          User?           @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "pc_builds_ibfk_1")

  @@index([user_id], map: "user_id")
  @@map("pc_builds")
}

model ProductSku {
  id             Int              @id @default(autoincrement())
  product_id     Int?
  price          Decimal?         @db.Decimal(10, 2)
  stock          Int?
  sku            String?          @db.VarChar(255)
  image_url      String?          @db.VarChar(255)
  status         String?          @default("ACTIVE") @db.VarChar(50)
  is_active      Boolean?         @default(true)
  created_at     DateTime?        @default(now()) @db.Timestamp(0)
  updated_at     DateTime?        @default(now()) @db.Timestamp(0)
  CartItem     CartItem[]
  OrderItem    OrderItem[]
  PcBuildItem PcBuildItem[]
  Product       Product?        @relation(fields: [product_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "product_skus_ibfk_1")
  SkuAttribute SkuAttribute[]

  @@index([product_id], map: "product_id")
  @@map("product_skus")
}

model ProductVariant {
  id             Int       @id @default(autoincrement())
  product_id     Int
  sku            String    @db.VarChar(255)
  price          Decimal   @default(0.00) @db.Decimal(12, 2)
  stock_quantity Int       @default(0)
  image_url      String?   @db.VarChar(255)
  status         String?   @default("ACTIVE") @db.VarChar(50)
  is_active      Boolean?  @default(true)
  created_at     DateTime? @default(now()) @db.Timestamp(0)
  updated_at     DateTime? @default(now()) @db.Timestamp(0)
  Product       Product  @relation(fields: [product_id], references: [id], onUpdate: Restrict, map: "fk_product_variants_product")

  @@index([product_id], map: "fk_product_variants_product")
  @@map("product_variants")
}

model Product {
  id               Int                @id @default(autoincrement())
  name             String?            @db.VarChar(255)
  description      String?            @db.Text
  price            Decimal?           @db.Decimal(10, 2)
  category_id      Int?
  created_at       DateTime           @default(now()) @db.Timestamp(0)
  slug             String?            @db.VarChar(255)
  brand_id         Int?
  status           String?            @default("ACTIVE") @db.VarChar(50)
  is_active        Boolean?           @default(true)
  updated_at       DateTime?          @default(now()) @db.Timestamp(0)
  ProductSku     ProductSku[]
  ProductVariant ProductVariant[]
  Brand           Brand?            @relation(fields: [brand_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_products_brand")
  Category       Category?        @relation(fields: [category_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "products_ibfk_1")

  @@index([category_id], map: "category_id")
  @@index([brand_id], map: "fk_products_brand")
  @@map("products")
}

model Role {
  id    Int     @id @default(autoincrement())
  name  String? @unique(map: "name") @db.VarChar(50)
  User User[]
  @@map("roles")
}

model Shipment {
  id            Int     @id @default(autoincrement())
  order_id      Int?
  status        String? @db.VarChar(50)
  tracking_code String? @db.VarChar(100)
  Order        Order? @relation(fields: [order_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "shipments_ibfk_1")

  @@index([order_id], map: "order_id")
  @@map("shipments")
}

model SkuAttribute {
  id                 Int               @id @default(autoincrement())
  sku_id             Int?
  attribute_value_id Int?
  ProductSku       ProductSku?     @relation(fields: [sku_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "sku_attributes_ibfk_1")
  AttributeValue   AttributeValue? @relation(fields: [attribute_value_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "sku_attributes_ibfk_2")

  @@index([attribute_value_id], map: "attribute_value_id")
  @@index([sku_id], map: "sku_id")
  @@map("sku_attributes")
}

model TicketMessage {
  id         Int      @id @default(autoincrement())
  ticket_id  Int
  user_id    Int
  message    String   @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @db.Timestamp(0)
  Ticket    Ticket  @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_ticket_messages_ticket")
  User      User    @relation(fields: [user_id], references: [id], onUpdate: Restrict, map: "fk_ticket_messages_user")

  @@index([user_id], map: "fk_ticket_messages_user")
  @@index([ticket_id, created_at], map: "idx_ticket_messages_ticket_created")
  @@map("ticket_messages")
}

model Ticket {
  id                                  Int               @id @default(autoincrement())
  user_id                             Int
  title                               String            @db.VarChar(255)
  description                         String            @db.Text
  status                              String            @default("OPEN") @db.VarChar(50)
  priority                            String            @default("MEDIUM") @db.VarChar(50)
  assigned_to_id                      Int?
  created_at                          DateTime          @default(now()) @db.Timestamp(0)
  updated_at                          DateTime          @default(now()) @db.Timestamp(0)
  TicketMessage                     TicketMessage[]
  users_tickets_assigned_to_idTousers User?            @relation("tickets_assigned_to_idTousers", fields: [assigned_to_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_tickets_assignee")
  users_tickets_user_idTousers        User             @relation("tickets_user_idTousers", fields: [user_id], references: [id], onUpdate: Restrict, map: "fk_tickets_user")

  @@index([assigned_to_id, status], map: "idx_tickets_assigned_status")
  @@index([user_id, status], map: "idx_tickets_user_status")
  @@map("tickets")
}

model User {
  id                                    Int               @id @default(autoincrement())
  email                                 String?           @unique(map: "email") @db.VarChar(100)
  password                              String?           @db.VarChar(255)
  full_name                             String?           @db.VarChar(100)
  role_id                               Int?
  created_at                            DateTime          @default(now()) @db.Timestamp(0)
  status                                String?           @default("ACTIVE") @db.VarChar(50)
  updated_at                            DateTime?         @default(now()) @db.Timestamp(0)
  phone                                 String?           @db.VarChar(30)
  Address                             Address[]
  AiChat                              AiChat[]
  Cart                                 Cart[]
  PcBuild                             PcBuild[]
  TicketMessage                       TicketMessage[]
  tickets_tickets_assigned_to_idTousers Ticket[]         @relation("tickets_assigned_to_idTousers")
  tickets_tickets_user_idTousers        Ticket[]         @relation("tickets_user_idTousers")
  Role                                 Role?            @relation(fields: [role_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "users_ibfk_1")
  WarrantyItem                            WarrantyItem[]

  @@index([role_id], map: "role_id")
  @@map("users")
}

model WarrantyItem {
  id            Int          @id @default(autoincrement())
  user_id       Int
  order_id      Int?
  order_item_id Int?         @unique(map: "uq_warranty_order_item")
  sku_id        Int?
  warranty_code String       @unique(map: "uq_warranty_code") @db.VarChar(100)
  status        String       @default("ACTIVE") @db.VarChar(50)
  note          String?      @db.VarChar(255)
  activated_at  DateTime?    @db.DateTime(0)
  expires_at    DateTime?    @db.DateTime(0)
  created_at    DateTime     @default(now()) @db.Timestamp(0)
  Order        Order?      @relation(fields: [order_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_warranties_order")
  OrderItem   OrderItem? @relation(fields: [order_item_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_warranties_order_item")
  User         User        @relation(fields: [user_id], references: [id], onUpdate: Restrict, map: "fk_warranties_user")

  @@index([order_id], map: "fk_warranties_order")
  @@index([user_id], map: "fk_warranties_user")
  @@map("warranties")
}
